# Vercel Postgres — get from Vercel dashboard
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# NextAuth — run: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-app.vercel.app

# Railway WhatsApp Service
RAILWAY_WHATSAPP_URL=https://your-service.railway.app
RAILWAY_WHATSAPP_SECRET=

# Public base URL of the Next.js app
NEXT_PUBLIC_BOOKING_URL=https://your-app.vercel.app

# Optional: for Settings page WA status check
NEXT_PUBLIC_RAILWAY_STATUS_URL=https://your-service.railway.app
